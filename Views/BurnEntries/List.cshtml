@model List<BurnBook.Models.Entities.BurnEntry>

<h1>Burn Book Entries</h1>

<a class="btn btn-primary"
       asp-controller="BurnEntries"
       asp-action="Add">
    Add Entry
</a>

<table class="table">

    <tr>
        <th>Nickname</th>
        <th>Message</th>
        <th>Category</th>
        <th>Actions</th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Nickname</td>
            <td>@item.Message</td>
            <td>@item.Category</td>
            <td>

                <a class="btn btn-warning"
                       asp-action="Edit"
                       asp-route-id="@item.Id">
                    Edit
                </a>

                <form method="post"
                      asp-action="Delete"
                      asp-route-id="@item.Id"
                      style="display:inline">

                    <button class="btn btn-danger"
                            onclick="return confirm('Delete this burn entry?')">
                        Delete
                    </button>

                </form>

            </td>
        </tr>
    }

</table>