@model BurnBook.Models.AddBurnEntryViewModel

<h1>Add Burn Entry</h1>

<form method="post">

    <div class="mt-3">
        <label>Nickname</label>
        <input type="text"
               asp-for="Nickname"
               class="form-control" />
    </div>

    <div class="mt-3">
        <label>Message</label>
        <textarea asp-for="Message"
                  class="form-control"></textarea>
    </div>

    <div class="mt-3">
        <label>Category</label>

        <select asp-for="Category"
                class="form-control">

            <option>Tea</option>
            <option>Funny</option>
            <option>School</option>
            <option>Random</option>

        </select>

    </div>

    <div class="mt-3">
        <button class="btn btn-primary">
            Save
        </button>
    </div>

</form>
